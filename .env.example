# Supabase project URL used by the browser client
VITE_SUPABASE_URL=https://your-project.supabase.co
# Supabase publishable/anon key used by the browser client
VITE_SUPABASE_ANON_KEY=sb_publishable_or_anon_key
# Gogi-scoped table and storage prefix used by the browser client
VITE_TABLE_PREFIX=usr_yourprefix
